# ── Store Mode ──────────────────────────────────────────────────────────────
USE_LOCAL_STORES=true
USE_SUPABASE=false

# ── PostgreSQL (local Docker) ────────────────────────────────────────────────
POSTGRES_USER=logios
POSTGRES_DB=logios_brain
POSTGRES_PASSWORD=<your-postgres-password>

DATABASE_URL=postgresql://logios:<your-postgres-password>@127.0.0.1:5432/logios_brain

# ── Supabase (cloud — only used when USE_SUPABASE=true) ─────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-key>
SUPABASE_PROJECT_REF=<your-supabase-project-ref>

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=<your-qdrant-api-key>

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-neo4j-password>

# ── Auth ─────────────────────────────────────────────────────────────────────
# Deployer secret — only the person with server access can create the first owner.
# Generate with: openssl rand -hex 32
SECRET_KEY=<deployer-secret-key>
# JWT signing key — must be different from SECRET_KEY.
# Generate with: openssl rand -hex 32
ACCESS_SECRET_KEY=<jwt-signing-key>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Email (OTP delivery) ─────────────────────────────────────────────────────
EMAILS_ENABLED=false
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=<smtp-username>
SMTP_PASSWORD=<smtp-password>
EMAILS_FROM_NAME=Logios Brain
EMAILS_FROM_EMAIL=noreply@logios.local
EMAIL_OTP_EXPIRE_MINUTES=10

# ── Server ─────────────────────────────────────────────────────────────────
SERVER_PORT=8000

# ── LLM / GenAI ────────────────────────────────────────────────────────────────
LLM_API_KEY=<your-llm-api-key>
LLM_PROVIDER=nvidia  # nvidia | openai | anthropic | gemini

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_URL=https://integrate.api.nvidia.com/v1/embeddings
EMBEDDING_MODEL=nvidia/nv-embed-v1
EMBEDDING_DIM=4096

# ── Entity Extraction ───────────────────────────────────────────────────────────
ENTITY_COMPLETION_URL=https://integrate.api.nvidia.com/v1/chat/completions
ENTITY_MODEL=microsoft/phi-3-mini-128k-instruct

# ── Redis ──────────────────────────────────────────────────────────────────────
# Docker: use the service name. Host: use localhost.
REDIS_URL=redis://localhost:6379/0
